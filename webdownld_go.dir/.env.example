# 服务基础配置
APP_ADDR=:8188
DATA_ROOT=./data
STORAGE_NODE_IDS=node-a,node-b,node-c
STORAGE_NODE_ADDRS=127.0.0.1:9001,127.0.0.1:9002,127.0.0.1:9003
RAFT_HTTP_NODES=127.0.0.1:8080,127.0.0.1:8081,127.0.0.1:8082
CHUNK_SIZE_MB=4
MAX_CONCURRENT_CHUNK_WRITES=64

# MySQL 数据库
MYSQL_DSN=root:root@tcp(127.0.0.1:3306)/cloudraft?parseTime=true&charset=utf8mb4

# JWT 鉴权
JWT_SECRET=cloudraft-jwt-secret-change-me-in-production
JWT_ACCESS_TTL_HOURS=2
JWT_REFRESH_TTL_DAYS=7

# RabbitMQ 消息队列
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/

# 支付宝支付（沙箱环境）
ALIPAY_APP_ID=your-app-id
ALIPAY_PRIVATE_KEY=your-private-key
ALIPAY_PUBLIC_KEY=your-alipay-public-key
ALIPAY_NOTIFY_URL=https://your-domain.com/api/payment/notify
ALIPAY_RETURN_URL=https://your-domain.com/payment/return
ALIPAY_IS_PRODUCTION=false
